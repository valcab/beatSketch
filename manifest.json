{
  "manifest_version": 3,
  "name": "BeatSketch",
  "version": "0.1.0",
  "description": "Boite a rythme Chrome pour guitaristes et bassistes avec Web Audio API.",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": ["storage", "activeTab"],
  "action": {
    "default_title": "BeatSketch",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "web_accessible_resources": [
    {
      "resources": ["assets/*", "assets/drums/*", "assets/drums/**/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
